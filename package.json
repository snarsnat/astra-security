{
  "name": "astra-security",
  "version": "1.0.0",
  "description": "A comprehensive security verification system with deep layer analysis, adaptive challenges, and accessibility features",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "node dist/test.js",
    "dev": "ts-node src/test.ts",
    "prepublishOnly": "npm run build",
    "postinstall": "node setup.js"
  },
  "keywords": [
    "security",
    "verification",
    "authentication",
    "accessibility",
    "biometrics",
    "behavioral",
    "challenge-response",
    "risk-analysis",
    "adaptive-security"
  ],
  "author": "Astra Security Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/snarsnat/astra-security.git"
  },
  "bugs": {
    "url": "https://github.com/snarsnat/astra-security/issues"
  },
  "homepage": "https://astra.security",
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/redis": "^4.0.10",
    "axios": "^1.6.0",
    "crypto-js": "^4.2.0",
    "jsonwebtoken": "^9.0.3",
    "open": "^9.1.0",
    "redis": "^5.11.0",
    "uuid": "^9.0.0",
    "ws": "^8.14.2"
  },
  "bin": {
    "astra": "./bin/astra.js"
  },
  "devDependencies": {
    "@types/crypto-js": "^4.2.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
